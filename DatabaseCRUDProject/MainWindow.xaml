<Window x:Class="DatabaseCRUDProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#F5F5F5">
        <Border Width="360" Padding="24" Background="White" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Sign in" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <TextBlock Text="CI" Margin="0,0,0,6"/>
                <TextBox x:Name="CiTextBox" Height="34" Margin="0,0,0,14"/>

                <TextBlock Text="Password" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Height="34" Margin="0,0,0,20"/>

                <Button Content="Sign in" Height="36" Click="SignIn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
