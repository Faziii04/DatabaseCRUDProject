<Window x:Class="DatabaseCRUDProject.Windows.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dashboard" Height="520" Width="920"
        Background="{DynamicResource MainBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Menu" Foreground="{DynamicResource SidebarForegroundBrush}" FontSize="20" FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <TextBlock x:Name="LoggedInUserTextBlock" Foreground="{DynamicResource SidebarForegroundBrush}" Margin="16,0,16,16" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="12,8,12,12">
                    <Button Content="Home" Height="36" Margin="0,0,0,8" Click="HomeButton_Click"/>
                    <Button Content="Users" Height="36" Margin="0,0,0,8" Click="UsersButton_Click"/>
                    <Button Content="Settings" Height="36" Margin="0,0,0,8" Click="SettingsButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}" Padding="16">
            <ContentControl x:Name="DashboardContent"/>
        </Border>
    </Grid>
</Window>
