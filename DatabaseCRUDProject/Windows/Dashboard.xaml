<Window x:Class="DatabaseCRUDProject.Windows.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dashboard" Height="560" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="SidebarMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Menu"
                               Foreground="{DynamicResource SidebarForegroundBrush}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="4,2,4,10"/>
                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,16">
                        <TextBlock x:Name="LoggedInUserTextBlock"
                                   Foreground="{DynamicResource SidebarForegroundBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,8,0,0">
                    <Button Content="Home" Style="{StaticResource SidebarMenuButtonStyle}" Click="HomeButton_Click"/>
                    <Button Content="Users" Style="{StaticResource SidebarMenuButtonStyle}" Click="UsersButton_Click"/>
                    <Button Content="Settings" Style="{StaticResource SidebarMenuButtonStyle}" Click="SettingsButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14">
            <ContentControl x:Name="DashboardContent"/>
        </Border>
    </Grid>
</Window>
